{
  "name": "cave-mem",
  "version": "1.2.0",
  "description": "Combined caveman-style compression + persistent cross-session memory backed by SQLite. Cuts output tokens ~75%, stores memories in compressed format, full-text search across sessions — double savings, single plugin.",
  "author": {
    "name": "cave-mem contributors"
  },
  "keywords": [
    "claude",
    "claude-code",
    "memory",
    "compression",
    "caveman",
    "tokens",
    "persistence"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/cave-mem-activate.js",
            "timeout": 8,
            "statusMessage": "Loading cave-mem (caveman + memory)..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/cave-mem-mode-tracker.js",
            "timeout": 5,
            "statusMessage": "Tracking cave-mem mode..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/cave-mem-observer.js",
            "async": true
          }
        ]
      }
    ]
  }
}
