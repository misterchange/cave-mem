{
  "name": "stoneage",
  "version": "1.3.0",
  "description": "stoneage — raw, honest context compression for local AI coders. Terse output compression + persistent cross-session memory backed by SQLite. Cuts output tokens ~75%, stores memories compressed, FTS across sessions, interactive graph viz + copy-paste AI handoff URL so any AI coder (Cursor/Windsurf/Claude Code/ChatGPT) gets full project context instantly.",
  "author": {
    "name": "stoneage contributors"
  },
  "keywords": [
    "claude",
    "claude-code",
    "memory",
    "compression",
    "stoneage",
    "tokens",
    "persistence"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/stoneage-activate.js",
            "timeout": 8,
            "statusMessage": "Loading stoneage (compression + memory)..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/stoneage-mode-tracker.js",
            "timeout": 5,
            "statusMessage": "Tracking stoneage mode..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/stoneage-observer.js",
            "async": true
          }
        ]
      }
    ]
  }
}
